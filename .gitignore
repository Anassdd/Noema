# ---- Secrets / config -------------------------------------------------------
# Real env files hold the OpenAI/Azure keys — never commit. .env.example stays.
.env
*.env
!.env.example
backend/.env

# ---- Python (backend) -------------------------------------------------------
backend/.venv/
backend/.venv-graph/
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ============================================================================
# Data policy — what syncs across machines (Mac ↔ Windows) via GitHub.
#
# TRACKED (the shared knowledge — so a clone answers without re-ingesting; these
# paths are deliberately NOT ignored, listed here as documentation only):
#   backend/.chroma/            RAG vector base
#   tests/results/graph_store/  Graphiti/FalkorDB graph + its saves
#   backend/data/lightrag/      LightRAG stores + saves
#   backend/data/bench/         bench datasets + prepared corpora
#   tests/results/bench/        bench runs/results
#
# PRIVATE — never committed (per-account data + secrets). Auth is the hard line;
# conversations, personal memory and beliefs are per-user and stay on each box.
# ============================================================================

# Uploaded test PDFs (disposable — parsed to text, never stored server-side).
backend/chroma/
chroma_db/
backend/uploads/
*.pdf

# Lab RAG store (Chroma sqlite + HNSW binaries) — regenerated on every lab run;
# churns as binary noise in git. Untrack once with:
#   git rm -r --cached tests/results/rag_store/
tests/results/rag_store/

# Bench data lives in the separate noema-bench-data repo (datasets, prepared
# workdirs, run archives — see .env BENCH_*_DIR). These legacy in-repo locations
# stay ignored so an unconfigured checkout never re-pollutes the product repo.
tests/results/bench/
tests/results/bench_archive/
backend/data/bench/

# Accounts + sessions (salted password hashes and tokens).
backend/data/auth/

# Per-account personal memory (saved via /remember). backend/data/memory/ holds
# one file per user; the app/memory.* pair is the dormant pre-account global memory.
backend/data/memory/
backend/memory.json
backend/app/memory.json
backend/app/memory.md

# Per-account beliefs (per-memory-context notes injected into answers).
backend/.beliefs/

# Persisted co-occurrence graph memory (the InfraNodus-style graph) — local.
backend/app/textgraph_store/

# Per-account conversations (SQLite) — can hold personal chats.
backend/app/conversations.db

# ---- Node / frontend --------------------------------------------------------
node_modules/
frontend/node_modules/
frontend/dist/
dist/
*.local
.vite/

# ---- Logs -------------------------------------------------------------------
*.log
npm-debug.log*

# ---- OS / editor ------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ---- Induced per-domain graph schemas (regenerable playground artifacts) ----
tests/results/graph_schemas/

# Claude Code local state — never in git (CLAUDE.md stays: it's the project spec).
.claude/
