# ---- Secrets / config -------------------------------------------------------
# Real env files hold the OpenAI/Azure keys — never commit. .env.example stays.
.env
*.env
!.env.example
backend/.env

# ---- Python (backend) -------------------------------------------------------
backend/.venv/
backend/.venv-graph/
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Vector store / uploads (disposable, regenerable) -----------------------
# Chroma persistence + any locally uploaded test PDFs. Never carried between
# machines per the spec — re-ingest instead.
backend/chroma/
backend/.chroma/
chroma_db/
backend/uploads/
*.pdf

# ---- Graph store (embedded FalkorDB Lite .rdb binaries) ---------------------
# Regenerable; the kept edge-case results live as JSON in tests/results/graph_runs/.
tests/results/graph_store/

# Lab RAG store (Chroma sqlite + HNSW binaries) — regenerated on every lab run;
# churns as binary noise in git. Untrack once with:
#   git rm -r --cached tests/results/rag_store/
tests/results/rag_store/

# Persisted user memory (saved via /remember) — local, can hold personal facts.
backend/memory.json
backend/app/memory.json
backend/app/memory.md

# User beliefs (per-memory-context notes, injected into answers) — local user data.
backend/.beliefs/

# Persisted co-occurrence graph memory (the InfraNodus-style graph) — local user data.
backend/app/textgraph_store/

# Durable conversation store (SQLite) — local, can hold personal chats.
backend/app/conversations.db

# ---- Node / frontend --------------------------------------------------------
node_modules/
frontend/node_modules/
frontend/dist/
dist/
*.local
.vite/

# ---- Logs -------------------------------------------------------------------
*.log
npm-debug.log*

# ---- OS / editor ------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ---- Induced per-domain graph schemas (regenerable playground artifacts) ----
tests/results/graph_schemas/
