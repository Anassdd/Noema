# Copy to backend/.env and fill in. Never commit the real .env.
# Provider switch:
#   openai -> local dev (Mac), personal OpenAI key
#   llmaas -> the work Azure OpenAI-compatible endpoint (/v1)
LLM_PROVIDER=openai

# --- OpenAI — local dev (Mac) ----------------------------------------------
# Required when LLM_PROVIDER=openai.
OPENAI_API_KEY=sk-...
# Optional — these are the defaults if unset.
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- LLMaaS — Azure OpenAI-compatible endpoint (/v1) -----------------------
# Required when LLM_PROVIDER=llmaas. Speaks the OpenAI API at a custom /v1 URL.
# LLMAAS_API_KEY is OPTIONAL — leave it unset for a keyless gateway (the app
# sends a placeholder the server ignores).
LLMAAS_BASE_URL=https://<host>/v1
LLMAAS_CHAT_MODEL=<model name the endpoint expects>
LLMAAS_API_KEY=
LLMAAS_EMBED_MODEL=        # only needed once RAG embeddings are wired up
