# Copy to backend/.env and fill in. Never commit the real .env.
# Provider switch:
#   openai -> local dev (Mac), personal OpenAI key
#   llmaas -> the work Azure OpenAI-compatible endpoint (/v1)
LLM_PROVIDER=openai

# --- OpenAI — local dev (Mac) ----------------------------------------------
# Required when LLM_PROVIDER=openai.
OPENAI_API_KEY=sk-...
# Optional — these are the defaults if unset.
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_EMBED_MODEL=text-embedding-3-large
# The STRONG model: parses PDFs (render page -> image -> Markdown+LaTeX) and
# extracts the graph. Must be vision-capable; current flagship recommended.
OPENAI_PARSE_MODEL=gpt-5.4

# --- Bench judge (optional) -------------------------------------------------
# A separate OpenAI-compatible endpoint that SCORES bench answers, so the judge
# can be a different model family than the generator. On the Mac: Gemini's
# OpenAI-compatible endpoint — get a free key at https://aistudio.google.com.
# The judge endpoint is used only when ALL THREE are set; with the key empty it
# safely falls back to the main provider's chat model (what the company does).
JUDGE_MODEL=gemini-2.5-flash
JUDGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
JUDGE_API_KEY=
# Verdicts run after generation (never gating it), JUDGE_CONCURRENCY in parallel.
# JUDGE_RPM paces calls globally — set ~9 ONLY for a rate-limited free tier; unset = full speed.
JUDGE_CONCURRENCY=4
# JUDGE_RPM=9

# --- LLMaaS — Azure OpenAI-compatible endpoint (/v1) -----------------------
# Required when LLM_PROVIDER=llmaas. Speaks the OpenAI API at a custom /v1 URL.
# LLMAAS_API_KEY is OPTIONAL — leave it unset for a keyless gateway (the app
# sends a placeholder the server ignores).
LLMAAS_BASE_URL=https://<host>/v1
LLMAAS_CHAT_MODEL=<model name the endpoint expects>
LLMAAS_API_KEY=
LLMAAS_EMBED_MODEL=        # embeddings deployment for the RAG vector base
# Vision-capable deployment for PDF parsing; falls back to LLMAAS_CHAT_MODEL if unset.
LLMAAS_PARSE_MODEL=

# --- Parser backend (orthogonal to LLM provider) ---------------------------
# vision   -> render pages -> the vision model above (default; works on dev + prod)
# docintel -> Azure Document Intelligence (deterministic, in-tenant, page provenance)
PARSER=vision
# Required only when PARSER=docintel:
DOCINTEL_ENDPOINT=https://<your-di-resource>.cognitiveservices.azure.com/
DOCINTEL_KEY=

# --- Retrieval reranking ----------------------------------------------------
# Re-reads the fused candidate chunks against the question before the top-k cut.
# llm      -> RankGPT-style listwise rerank via the normal chat endpoint (default;
#             one cheap call per retrieval, works on dev and the gateway)
# endpoint -> a dedicated hosted reranker (set RERANK_MODEL + RERANK_BASE_URL[+KEY])
# off      -> no reranking (the pre-2026-07 behavior)
RETRIEVAL_RERANK=llm
RERANK_MODEL=
RERANK_BASE_URL=
RERANK_API_KEY=

# Contextualizer guard (retrieval/contextual.py): docs at/under CONTEXT_DOC_CAP tokens
# are situated against the WHOLE document (Anthropic recipe); larger docs against
# head+region excerpts of ~CONTEXT_PART_TOKENS. 250000 fits the whole GPT-5 family
# (usable input 272k); drop to ~100000 on a 128k-context model.
CONTEXT_DOC_CAP=250000
CONTEXT_PART_TOKENS=48000
# Blurb calls per document run 1 cache-priming call + CONTEXT_CONCURRENCY in parallel
# (1 = fully sequential — use on heavily rate-limited keys).
CONTEXT_CONCURRENCY=4

# Graph memory (Graphiti) search recipe: rrf (default — the measured baseline) |
# cross_encoder (LLM-reranked facts, ~graph_limit extra cheap calls per query) | mmr.
# Recorded in bench run provenance — never mix recipes within one comparison table.
GRAPH_SEARCH_RECIPE=rrf
# Cap Graphiti's internal concurrent LLM calls during ingestion.
# 0 = library default (~20); lower it on rate-limited keys or gateways.
GRAPH_MAX_COROUTINES=0

# Consolidated state root (optional — STORAGE.md §3). Empty = every store keeps its
# historical location. Set (e.g. backend/var) AFTER running scripts/migrate_state.py.
NOEMA_STATE_DIR=

# Admin account, guaranteed to exist at every backend startup — so any fresh
# deployment (a new machine, wiped auth files) is manageable immediately.
# DEFAULT: admin / admin. CHANGE THE PASSWORD after first sign-in (Settings ->
# Manage): the seeder promotes an existing account but never re-passwords it,
# so your change sticks. Set ADMIN_PASSWORD= (empty) to disable seeding.
# The FIRST account ever registered also becomes admin automatically.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
# Extra always-admin usernames (comma-separated), regardless of stored flags —
# the escape hatch for pre-flag accounts or locking yourself out.
ADMIN_USERS=
