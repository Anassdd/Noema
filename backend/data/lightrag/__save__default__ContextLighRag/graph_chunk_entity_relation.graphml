  <graph edgedefault="undirected">
    <node id="Prompt Caching">
      <data key="d0">Prompt Caching</data>
      <data key="d1">method</data>
      <data key="d2">A feature-based method that reduces the cost of Contextual Retrieval by allowing a reference document to be loaded into cache once and reused for subsequent chunk processing.</data>
      <data key="d3">doc-203bd2360f4004442b80c1fd54617dbf-chunk-000</data>
      <data key="d4">pasted text</data>
      <data key="d5">1783605149</data>
      <data key="d6" />
    </node>
    <node id="Contextual Retrieval">
      <data key="d0">Contextual Retrieval</data>
      <data key="d1">method</data>
      <data key="d2">A retrieval method described as uniquely possible at low cost with Claude when combined with prompt caching to generate contextualized chunks.</data>
      <data key="d3">doc-203bd2360f4004442b80c1fd54617dbf-chunk-000</data>
      <data key="d4">pasted text</data>
      <data key="d5">1783605149</data>
      <data key="d6" />
    </node>
    <node id="Claude">
      <data key="d0">Claude</data>
      <data key="d1">artifact</data>
      <data key="d2">A system or tool that enables Contextual Retrieval at low cost through a special prompt caching feature.</data>
      <data key="d3">doc-203bd2360f4004442b80c1fd54617dbf-chunk-000</data>
      <data key="d4">pasted text</data>
      <data key="d5">1783605149</data>
      <data key="d6" />
    </node>
    <node id="Reference Document">
      <data key="d0">Reference Document</data>
      <data key="d1">content</data>
      <data key="d2">A document that does not need to be passed for every chunk when prompt caching is used, because it can be loaded into cache once and referenced later.</data>
      <data key="d3">doc-203bd2360f4004442b80c1fd54617dbf-chunk-000</data>
      <data key="d4">pasted text</data>
      <data key="d5">1783605149</data>
      <data key="d6" />
    </node>
    <node id="Cache">
      <data key="d0">Cache</data>
      <data key="d1">artifact</data>
      <data key="d2">A storage mechanism into which the reference document is loaded once so that previously cached content can be referenced.</data>
      <data key="d3">doc-203bd2360f4004442b80c1fd54617dbf-chunk-000</data>
      <data key="d4">pasted text</data>
      <data key="d5">1783605149</data>
      <data key="d6" />
    </node>
    <node id="Chunk">
      <data key="d0">Chunk</data>
      <data key="d1">content</data>
      <data key="d2">A segment of content processed in contextual retrieval, assumed to contain 800 tokens and receive 100 tokens of context.</data>
      <data key="d3">doc-203bd2360f4004442b80c1fd54617dbf-chunk-000</data>
      <data key="d4">pasted text</data>
      <data key="d5">1783605149</data>
      <data key="d6" />
    </node>
    <node id="Document Tokens">
      <data key="d0">Document Tokens</data>
      <data key="d1">data</data>
      <data key="d2">A token-based measurement of document size used to express the one-time cost of generating contextualized chunks per million document tokens.</data>
      <data key="d3">doc-203bd2360f4004442b80c1fd54617dbf-chunk-000</data>
      <data key="d4">pasted text</data>
      <data key="d5">1783605149</data>
      <data key="d6" />
    </node>
    <node id="Context Instructions">
      <data key="d0">Context Instructions</data>
      <data key="d1">content</data>
      <data key="d2">Instructions associated with context generation, assumed to contain 50 tokens in the cost example.</data>
      <data key="d3">doc-203bd2360f4004442b80c1fd54617dbf-chunk-000</data>
